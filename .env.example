# Cytadel Scan — environment configuration (copy to .env, never commit .env)

# NVD CVE API 2.0 key — https://nvd.nist.gov/developers/request-an-api-key
# Raises the rate limit from ~5 req/30s to ~50 req/30s. Optional but strongly recommended.
CYTADEL_NVD_API_KEY=

# Path to the local SQLite vulnerability database (created by `cytadel-scan sync`).
CYTADEL_DB_PATH=./data/cytadel-vuln.sqlite

# Live-intel feed endpoints (override only if mirroring internally).
CYTADEL_NVD_API_URL=https://services.nvd.nist.gov/rest/json/cves/2.0
CYTADEL_KEV_URL=https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json
CYTADEL_EPSS_URL=https://api.first.org/data/v1/epss

# Default scan tuning (CLI flags override these).
CYTADEL_MAX_WORKERS=64
CYTADEL_CONNECT_TIMEOUT_MS=3000
