# Cytadel Scan -- /etc/cytadel/cytadel.env TEMPLATE (M9 Phase 4b).
#
# This is the ONLY place CYTADEL_NVD_API_KEY / CYTADEL_DB_PATH should ever
# be set for the scheduled sync job. Both the systemd unit
# (packaging/systemd/cytadel-sync.service's EnvironmentFile=) and the cron
# wrapper (packaging/cron/cytadel-sync-cron-wrapper.sh) read them ONLY from
# a file at this exact path -- never inline in a unit file, never on a
# crontab line, never as a CLI argument (would be visible to any local user
# via `ps`/`/proc/<pid>/cmdline`).
#
# Install steps (see packaging/README.md for the full walkthrough):
#   sudo mkdir -p /etc/cytadel
#   sudo cp packaging/cytadel.env.example /etc/cytadel/cytadel.env
#   sudo chown root:root /etc/cytadel/cytadel.env
#   sudo chmod 0600 /etc/cytadel/cytadel.env
#   sudo <edit /etc/cytadel/cytadel.env, replace the placeholder key>
#
# NEVER commit a real key anywhere in this repository -- this template
# file's placeholder below is intentionally NOT a real or realistic-looking
# key (no UUID shape, no hex string that could be mistaken for one).

# NVD CVE API 2.0 key -- https://nvd.nist.gov/developers/request-an-api-key
# Raises the rate limit from ~5 req/30s to ~50 req/30s (src/net/nvd_fetch.c
# still works with this UNSET/empty -- it just runs at the lower anonymous
# rate limit -- but a scheduled unattended job should have one so a
# multi-window catch-up after downtime doesn't get rate-limited).
CYTADEL_NVD_API_KEY=REPLACE_ME_WITH_A_REAL_NVD_API_KEY

# Path to the local SQLite vulnerability database this sync job reads and
# writes. Must be a directory this job's own (unprivileged) user can write
# to:
#   - systemd path: cytadel-sync.service's StateDirectory=cytadel already
#     creates and owns /var/lib/cytadel for you -- leave this as-is.
#   - cron path: packaging/README.md has you `mkdir -p /var/lib/cytadel &&
#     chown cytadel-sync:cytadel-sync /var/lib/cytadel` by hand first.
CYTADEL_DB_PATH=/var/lib/cytadel/cytadel-vuln.sqlite

# Optional override -- only needed if internally mirroring the NVD feed.
# Uncomment and point at the mirror; leave commented to use the compiled-in
# default (services.nvd.nist.gov). See the top-level .env.example for the
# full set of overrides this project supports (CYTADEL_KEV_URL,
# CYTADEL_EPSS_URL, etc.) -- `sync` itself only ever reads this one.
#CYTADEL_NVD_API_URL=https://services.nvd.nist.gov/rest/json/cves/2.0
